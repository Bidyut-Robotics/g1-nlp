{
  "hardware_mode": "g1",
  "nlp_debug": true,

  "laptop": {
    "echo_cancel": false
  },

  "robot_info": {
    "name": "Jarvis",
    "company": "Jindal Steel",
    "location": "Jindal Steel, Delhi",
    "role": "Office assistant robot"
  },

  "g1": {
    "dds_interface": "eth0",
    "local_ip": "192.168.123.164",
    "mic_device_name": null,
    "speaker_player_args": [],
    "gestures_enabled": false
  },

  "llm": {
    "mode": "local",
    "groq": {
      "model": "llama-3.1-8b-instant",
      "temperature": 0.1,
      "max_tokens": 150
    },
    "local": {
      "model_name": "llama3.2:1b",
      "base_url": "http://localhost:11434",
      "temperature": 0.7,
      "num_predict": 100,
      "num_ctx": 2048,
      "keep_alive": "30m"
    },
    "enterprise": {
      "model": "gpt-4o",
      "base_url": "https://api.openai.com/v1",
      "temperature": 0.1,
      "max_tokens": 200
    }
  },

  "tts": {
    "mode": "g1_direct",
    "model_path": "models/en_US-lessac-medium.onnx",
    "hindi_model_path": "models/hi_IN-priyamvada-medium.onnx",
    "player": "aplay"
  },

  "asr": {
    "model_size": "base",
    "device": "cpu",
    "compute_type": "int8"
  },

  "wake_word": {
    "model": "models/hey_jarvis_v0.1.onnx",
    "display_name": "Jarvis",
    "threshold": 0.3
  }
}
