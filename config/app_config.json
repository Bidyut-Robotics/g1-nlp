{
  "hardware_mode": "g1",
  "nlp_debug": true,

  "laptop": {
    "echo_cancel": false
  },

  "robot_info": {
    "name": "Jarvis",
    "company": "Jindal Steel",
    "location": "Jindal Steel, Delhi",
    "role": "Office assistant robot"
  },

  "g1": {
    "dds_interface": "enP2p1s0",
    "local_ip": "192.168.123.166",
    "mic_device_name": null,
    "speaker_player_args": [],
    "gestures_enabled": true
  },

  "llm": {
    "mode": "local",
    "groq": {
      "model": "llama-3.1-8b-instant",
      "temperature": 0.1,
      "max_tokens": 150
    },
    "local": {
      "model_name": "qwen2.5:7b",
      "base_url": "http://localhost:11434",
      "temperature": 0.1,
      "num_predict": 200,
      "num_ctx": 4096,
      "keep_alive": "30m"
    },
    "enterprise": {
      "model": "gpt-4o",
      "base_url": "https://api.openai.com/v1",
      "temperature": 0.1,
      "max_tokens": 200
    }
  },

  "tts": {
    "mode": "g1_bridge",
    "model_path": "models/en_US-ryan-medium.onnx",
    "hindi_model_path": "models/hi_IN-priyamvada-medium.onnx",
    "player": "aplay"
  },

  "asr": {
    "mode": "parakeet",
    "device": "cuda",
    "model_name": "nvidia/parakeet-tdt-0.6b-v2"
  },

  "wake_word": {
    "backend": "livekit",
    "model": "models/hey_jarvis_kaggle.onnx",
    "display_name": "Jarvis",
    "threshold": 0.45,
    "min_consec": 1
  },

  "knowledge_base": {
    "enabled": true,
    "url": "http://localhost:8000",
    "top_k": 8,
    "timeout_ms": 3000
  }
}
