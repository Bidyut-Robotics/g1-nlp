#!/bin/bash
# Environment setup for humanoid_nlp voice assistant
# Usage: source .env.example  (or copy to .env and source it)

# ============================================
# LLM Configuration
# ============================================
# Choose one: "groq" (cloud - fast, use for dev) | "local" (Ollama - offline) | "enterprise" (client ChatGPT)
export LLM_MODE=groq

# --- Groq Cloud (fastest for dev, free tier) ---
export GROQ_API_KEY="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"
export GROQ_MODEL="llama-3.1-8b-instant"

# --- Enterprise ChatGPT (share with client, details TBD) ---
# export LLM_MODE=enterprise
# export ENTERPRISE_API_BASE="https://api.openai.com/v1"     # Replace with client endpoint
# export ENTERPRISE_API_KEY="sk-..."                         # Client's API key
# export ENTERPRISE_MODEL="gpt-4o"                          # Or client model name

# --- Local Ollama (for offline / Jetson deployment) ---
export OLLAMA_BASE_URL="http://localhost:11434"
export LLM_MODEL="llama3.2:1b"   # Faster than phi3 on CPU

# ============================================
# Wake Word
# ============================================
# OpenWakeWord model — "hey_jarvis_v0.1" is the best available "Jarvis" model
# export WAKEWORD_MODEL="hey_jarvis_v0.1"
export WAKEWORD_MODEL="/home/surya/my_research/humanoid_nlp/models/jarvis.onnx"
export WAKEWORD_THRESHOLD=0.5

# ============================================
# ASR Settings
# ============================================
# tiny = fastest (~0.3s on CPU), base = more accurate (~0.8s on CPU)
# On Jetson: use "base" with device=cuda
export ASR_MODEL_SIZE="tiny"

# ============================================
# Audio / Microphone Settings
# ============================================
# export MIC_DEVICE=0      # Force a specific mic device index
export NLP_DEBUG=1          # Enable verbose debug logging

# ============================================
# TTS Settings
# ============================================
export TTS_PLAYER=aplay     # Options: aplay, paplay, sox
# export TTS_MODEL_PATH=models/en_US-lessac-medium.onnx
# export TTS_HINDI_MODEL_PATH=models/hi_IN-priyamvada-medium.onnx

# ============================================
# ROS Integration (optional)
# ============================================
# export ROS_ACTION_TOPIC=/humanoid/nlp/actions

echo "✅ Environment loaded!"
echo "LLM Mode: $LLM_MODE | Model: $GROQ_MODEL | Wake: $WAKEWORD_MODEL | Debug: $NLP_DEBUG"
